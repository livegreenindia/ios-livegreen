rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Activities: read public, write only admin
    match /activities/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Users top-level document - user can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // Users subcollections - user can read/write their own data, admin can read
    match /users/{userId}/{sub=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // Provider tokens under a user: the user may write their own provider tokens, admin may read
    match /users/{userId}/providers/{providerId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Forum: posts are public read, only admins can create posts, authenticated can comment/like
    match /forumPosts/{postId} {
      allow read: if true;
      // Only admins can create posts
      allow create: if request.auth != null && 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;

      // Anyone authenticated can comment
      match /comments/{commentId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }

      // Anyone authenticated can like
      match /likes/{likeId} {
        allow create: if request.auth != null && request.auth.uid == likeId;
        allow read: if true;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }

    // Daily metrics: users can read their own metrics
    match /daily_metrics/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Default: deny
    match /{document=**} { allow read, write: if false; }
  }
}
