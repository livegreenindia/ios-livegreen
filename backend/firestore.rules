rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    function isAdminByRole() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Activities: read public, write only admin
    match /activities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users top-level document - user can read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin() || isAdminByRole();
      
      // User's recorded tracks subcollection
      match /tracks/{trackId} {
        allow read, write: if isOwner(userId);
        allow create: if isOwner(userId) && 
                        request.resource.data.userId == userId;
      }
      
      // User's favorites subcollection
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
      
      // User's custom routes subcollection
      match /customRoutes/{routeId} {
        allow read, write: if isOwner(userId);
      }
      
      // User's other subcollections (catch-all for existing)
      match /{sub=**} {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin() || isAdminByRole();
      }
    }

    // Provider tokens under a user
    match /users/{userId}/providers/{providerId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Forum: posts are public read, only admins can create posts
    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if isAdminByRole();
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;

      match /comments/{commentId} {
        allow create: if isAuthenticated();
        allow read: if true;
        allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }

      match /likes/{likeId} {
        allow create: if isAuthenticated() && request.auth.uid == likeId;
        allow read: if true;
        allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }

    // Daily metrics: users can read/write their own metrics
    match /daily_metrics/{docId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Payments: Razorpay payment records
    match /payments/{orderId} {
      // Users can read their own payment records, admins can read all
      allow read: if isAuthenticated() && 
                    (resource.data.uid == request.auth.uid || isAdmin() || isAdminByRole());
      // Only backend (admin service account) can create/update payment records
      // Users cannot directly write to payments collection
      allow create, update: if false; // Only backend via Admin SDK
      // Only admins can delete payment records
      allow delete: if isAdmin() || isAdminByRole();
    }

    // Pending Places: user-submitted places awaiting admin approval
    match /pendingPlaces/{placeId} {
      // Admins can read all, users can read their own submissions
      allow read: if isAdmin() || isAdminByRole() ||
                    (isAuthenticated() && resource.data.submittedBy == request.auth.uid);
      // Authenticated users can submit places
      allow create: if isAuthenticated() && 
                      request.resource.data.submittedBy == request.auth.uid;
      // Only admins can approve/reject (update or delete)
      allow update, delete: if isAdmin() || isAdminByRole();
    }

    // Trek Explorer: Treks collection
    match /treks/{trekId} {
      // Allow read for:
      // 1. All authenticated users (client filters public/private)
      // 2. Unauthenticated users can only read public treks (single doc reads)
      // Note: Collection queries require auth to prevent abuse
      allow read: if isAuthenticated() || resource.data.isPublic == true;
      
      // Authenticated users can create treks
      allow create: if isAuthenticated() && 
                      request.resource.data.createdBy == request.auth.uid;
      // Only creator or admin can update/delete
      allow update, delete: if isAuthenticated() && 
                              (resource.data.createdBy == request.auth.uid || isAdmin());
      
      // Trek reviews subcollection (nested under trek)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                        request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() && 
                                resource.data.userId == request.auth.uid;
      }
    }

    // Trek Reviews (top-level collection for backward compatibility)
    match /trek_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                              resource.data.userId == request.auth.uid;
    }

    // Recorded Tracks (legacy top-level collection)
    match /recorded_tracks/{trackId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && 
                    (resource == null || resource.data.userId == request.auth.uid) &&
                    request.resource.data.userId == request.auth.uid;
    }

    // Clubs: Ecology community clubs
    match /clubs/{clubId} {
      // Read: approved clubs are public, pending/rejected only by admin/creator
      allow read: if resource.data.status == 'approved' ||
                     isAdmin() || isAdminByRole() ||
                     (isAuthenticated() && resource.data.creatorId == request.auth.uid);
      
      // Create: authenticated users can create pending clubs
      allow create: if isAuthenticated() && 
                      request.resource.data.creatorId == request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.memberIds.hasAll([request.auth.uid]) &&
                      request.resource.data.leaderIds.hasAll([request.auth.uid]);
      
      // Update: creator can update pending clubs, admin can approve/reject, leaders can edit approved clubs
      allow update: if isAuthenticated() && 
                      ((resource.data.status == 'pending' && resource.data.creatorId == request.auth.uid) ||
                       ((isAdmin() || isAdminByRole()) && (request.resource.data.status == 'approved' || 
                                      request.resource.data.status == 'rejected')) ||
                       (resource.data.status == 'approved' && resource.data.leaderIds.hasAny([request.auth.uid])));
      
      // Delete: only admin can delete
      allow delete: if isAdmin() || isAdminByRole();
      
      // Activities subcollection
      match /activities/{activityId} {
        // Read: approved clubs' activities are public
        allow read: if get(/databases/$(database)/documents/clubs/$(clubId)).data.status == 'approved' ||
                       get(/databases/$(database)/documents/clubs/$(clubId)).data.creatorId == request.auth.uid;
        
        // Create: club members can post activities
        allow create: if isAuthenticated() && 
                        get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds.hasAny([request.auth.uid]) &&
                        request.resource.data.authorId == request.auth.uid;
        
        // Update/Delete: author or club leaders only
        allow update, delete: if isAuthenticated() && 
                               (resource.data.authorId == request.auth.uid ||
                                get(/databases/$(database)/documents/clubs/$(clubId)).data.leaderIds.hasAny([request.auth.uid]));
      }
      
      // Members subcollection
      match /members/{memberId} {
        // Read: members list of approved clubs is public, pending club members only for members
        allow read: if get(/databases/$(database)/documents/clubs/$(clubId)).data.status == 'approved' ||
                       (isAuthenticated() && get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds.hasAny([request.auth.uid]));
        
        // Create/Update/Delete: handled by club service
        allow write: if isAuthenticated() && 
                      (get(/databases/$(database)/documents/clubs/$(clubId)).data.leaderIds.hasAny([request.auth.uid]) ||
                       isAdmin() || isAdminByRole());
      }
      
      // Messages subcollection
      match /messages/{messageId} {
        // Read: only club members can read messages
        allow read: if isAuthenticated() && 
                       get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds.hasAny([request.auth.uid]);
        
        // Create: only club members can send messages
        allow create: if isAuthenticated() && 
                        get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds.hasAny([request.auth.uid]) &&
                        request.resource.data.userId == request.auth.uid;
        
        // Update/Delete: only message author can delete their own messages
        allow update, delete: if isAuthenticated() && 
                               resource.data.userId == request.auth.uid;
      }
    }

    // Completions subcollection – allow admins to query via collectionGroup
    // (required for collectionGroup('completions') queries from the admin dashboard)
    match /{path=**}/completions/{docId} {
      allow read: if isAdmin() || isAdminByRole();
    }

    // Default: deny all unmatched paths
    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}
